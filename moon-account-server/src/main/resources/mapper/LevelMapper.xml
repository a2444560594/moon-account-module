<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.market.account.Mapper.LevelMapper">
    <select id="getLevelList" resultType="com.market.account.Dto.LevelDTO">
        SELECT
            *
        FROM
            sys_level_info
    </select>

    <select id="getLevelByLevelId" parameterType="java.lang.Integer" resultType="com.market.account.Dto.LevelDTO">
        SELECT
            *
        FROM
            sys_level_info
        WHERE
            level = #{level}
    </select>


</mapper>