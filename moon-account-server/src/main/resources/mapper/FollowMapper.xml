<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.market.account.Mapper.LevelMapper">
    <select id="getUserFollowIdList" parameterType="java.lang.Integer" resultType="java.lang.Integer">
        SELECT
            follow_id
        FROM
            sys_user_follow
        WHERE
            user_id = #{userId}
    </select>


</mapper>